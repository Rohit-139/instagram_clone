<%= render "layouts/header" %>

<div class="max-w-md mt-4 mx-auto bg-white rounded-xl shadow-md overflow-hidden md:max-w-2xl">
  <!-- Profile Header -->


  <div class="p-6">
    <div class="flex items-center space-x-4">
      <% if @profile.avatar.attached? %>
      <div class="flex-shrink-0">
         <%= image_tag @profile.avatar.representation(resize_to_limit:[600,600]) ,class:"h-16 w-16 rounded-full object-cover border-2 border-pink-500" %>  
         <% else %>
              <%= image_tag "download.jpeg",class:"h-16 w-16 rounded-full object-cover border-2 border-pink-500" %>
    <% end %>
    
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-lg font-bold text-gray-900 truncate"><%= @profile.name %></p>
        <p class="text-sm text-gray-500 truncate"><%= @profile.bio %></p>
        <div class="flex space-x-4 mt-2">
         <div class="flex space-x-4 mt-2"> <span class="text-sm font-medium text-gray-900"><%= @profile.user.posts.count %><span class="font-normal text-gray-500"> posts</span></span>
          <span class="text-sm font-medium text-gray-900">
            <%=link_to " #{@profile.user.followers.count}", profiles_path(follower: true, user: @profile.user) %> <span class="font-normal text-gray-500">followers</span></span>
          <span class="text-sm font-medium text-gray-900"><%=link_to " #{@profile.user.followees.count}", profiles_path(follower: false, user: @profile.user) %>  <span class="font-normal text-gray-500">following</span></span>
          </div>

          <% if (@profile.user == current_user) %>
          <div class="px-8 flex gap-2">
            <button  type ="submit" class="flex w-36 mx-auto justify-center rounded-md bg-indigo-500 px-3 py-1.5 text-sm/6 font-semibold text-white hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"> <%= link_to "Edit Posts" , post_page_path %></button>
             <button  type ="submit" class="flex w-36 mx-auto justify-center rounded-md bg-indigo-500 px-3 py-1.5 text-sm/6 font-semibold text-white hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"> <%= link_to "delete postss" , post_page_path %></button>


          </div>
          <% end %>
        </div>
      </div>
    </div>
    <div class="mt-4">
      <p class="text-gray-700"><%= @profile.about %></p>
      
    </div>

    <% if !(@profile.user == current_user) %>
    <div class="mt-4 flex space-x-2 p-2">
      <button class="flex-1 bg-pink-500 hover:bg-pink-600 text-white font-bold py-1 px-4 rounded-lg text-sm">
        <% if current_user.followees.include?(@profile.user)%>
        <%= link_to "Unfollow", unfollow_path(@profile.user), data: {turbo_method: :post} %>
        <% else %>
        <%= link_to "Follow", follow_path(@profile.user), data: { turbo_method: :post } %>
        <%end %>
      </button>
      <button class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-1 px-4 rounded-lg text-sm">
        Message
      </button>
    
    </div>
    <% end %>
  </div>
  
  
  <!-- Posts Grid -->
  <% if @posts.present? %>
  <div class="grid grid-cols-3 gap-1 p-2">
    <% @posts.each do |post| %>


    <div class="aspect-square bg-gray-100 relative group">
       <% if post.image.attached? %>
     <%= image_tag post.image.representation(resize_to_limit:[600,600]) ,class:"h-full w-full  object-cover" %>   
    <% end %>
      <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-30 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-200">

          
  
        <div class="flex space-x-4 text-white">
          <span class="flex items-center"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" /></svg> <%= post.likes.count %></span>
          <span class="flex items-center"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd" /></svg> <%= post.comments.count%></span>
        </div>
      </div>
    </div>
    <% end %>
    <% end %>
    
    
    </div>

    <% if (@profile.user == current_user) %>
    <div class="mt-6 p-2">
    <button  type ="submit" class="flex w-72 mx-auto justify-center rounded-md bg-indigo-500 px-3 py-1.5 text-sm/6 font-semibold text-white hover:bg-indigo-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-500"> <%= link_to "Edit Profile" , edit_profile_path(@profile) %></button>
  </div>
  <% end %>
  </div>
